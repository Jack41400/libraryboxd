# Keep Secret Key and Debug settings in .env for security and flexibility
SECRET_KEY=your-secret-key-here

# PostgreSQL connection config example:
DATABASE_URL=postgres://user:password@localhost/dbname

# Debug mode should be set to False in production for security reasons
DEBUG=True

# Allowed hosts for development, should be set to actual hostnames in production
ALLOWED_HOSTS=yourdomain.com,anotherdomain.com